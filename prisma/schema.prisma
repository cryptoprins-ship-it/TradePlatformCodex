generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Direction {
  LONG
  SHORT
}

enum SignalStatus {
  DETECTED
  TRADE_OPENED
  SKIPPED
}

enum TradeStatus {
  OPEN
  TP1_HIT
  TP2_HIT
  STOP_LOSS_HIT
  CLOSED
  CANCELLED
  SKIPPED
}

enum TradingMode {
  PAPER
}

enum BotRunStatus {
  RUNNING
  STOPPED
}

model BotRun {
  id            String        @id @default(cuid())
  name          String
  configHash    String        @unique
  configSnapshot Json
  status        BotRunStatus  @default(RUNNING)
  startedAt     DateTime      @default(now())
  lastSeenAt    DateTime      @default(now())
  stoppedAt     DateTime?

  signals        Signal[]
  trades         Trade[]
  strategyScores StrategyScore[]
  botLogs        BotLog[]

  @@map("bot_runs")
}

model Symbol {
  id         String   @id @default(cuid())
  symbol     String   @unique
  baseAsset  String
  quoteAsset String
  isActive   Boolean  @default(true)
  riskClass  String   @default("CORE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  candles Candle[]
  signals Signal[]
  trades  Trade[]

  @@map("symbols")
}

model Candle {
  id        String   @id @default(cuid())
  symbol    String
  timeframe String
  openTime  DateTime
  closeTime DateTime
  open      Decimal  @db.Decimal(20, 8)
  high      Decimal  @db.Decimal(20, 8)
  low       Decimal  @db.Decimal(20, 8)
  close     Decimal  @db.Decimal(20, 8)
  volume    Decimal  @db.Decimal(28, 8)
  createdAt DateTime @default(now())

  symbolRef Symbol @relation(fields: [symbol], references: [symbol])

  @@unique([symbol, timeframe, openTime])
  @@index([symbol, timeframe, closeTime])
  @@map("candles")
}

model Signal {
  id        String       @id @default(cuid())
  runId     String?
  symbol    String
  timeframe String
  direction Direction
  score     Int
  reason    String
  status    SignalStatus @default(DETECTED)
  createdAt DateTime     @default(now())

  run            BotRun?         @relation(fields: [runId], references: [id])
  symbolRef      Symbol          @relation(fields: [symbol], references: [symbol])
  trade          Trade?
  strategyScores StrategyScore[]

  @@index([runId, symbol, timeframe, createdAt])
  @@map("signals")
}

model Trade {
  id                  String      @id @default(cuid())
  runId               String?
  signalId            String?     @unique
  symbol              String
  timeframe           String
  direction           Direction
  entryPrice          Decimal     @db.Decimal(20, 8)
  stopLoss            Decimal     @db.Decimal(20, 8)
  takeProfit1         Decimal     @db.Decimal(20, 8)
  takeProfit2         Decimal     @db.Decimal(20, 8)
  exitPrice           Decimal?    @db.Decimal(20, 8)
  status              TradeStatus @default(OPEN)
  pnlPercentage       Decimal?    @db.Decimal(12, 4)
  riskReward          Decimal     @db.Decimal(12, 4)
  confidenceScore     Int
  technicalReason     String
  strategyModulesUsed Json
  fees                Decimal     @default(0) @db.Decimal(20, 8)
  slippage            Decimal     @default(0) @db.Decimal(20, 8)
  result              String?
  openedAt            DateTime    @default(now())
  closedAt            DateTime?
  mode                TradingMode @default(PAPER)

  run       BotRun?      @relation(fields: [runId], references: [id])
  signal    Signal?      @relation(fields: [signalId], references: [id])
  symbolRef Symbol       @relation(fields: [symbol], references: [symbol])
  events    TradeEvent[]

  @@index([runId, symbol, status, openedAt])
  @@map("trades")
}

model TradeEvent {
  id        String   @id @default(cuid())
  tradeId   String
  eventType String
  message   String
  price     Decimal? @db.Decimal(20, 8)
  createdAt DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [id])

  @@index([tradeId, createdAt])
  @@map("trade_events")
}

model StrategyScore {
  id        String   @id @default(cuid())
  runId     String?
  signalId  String
  module    String
  score     Int
  reason    String
  createdAt DateTime @default(now())

  run    BotRun? @relation(fields: [runId], references: [id])
  signal Signal  @relation(fields: [signalId], references: [id])

  @@index([runId, signalId])
  @@map("strategy_scores")
}

model BotLog {
  id        String   @id @default(cuid())
  runId     String?
  level     String
  message   String
  context   Json?
  createdAt DateTime @default(now())

  run BotRun? @relation(fields: [runId], references: [id])

  @@index([runId, level, createdAt])
  @@map("bot_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
