APP_NAME=TradePlatformCodex
NODE_ENV=development

TRADING_MODE=paper
ENABLE_LIVE_TRADING=false

EXCHANGE=MEXC
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,WLDUSDT
TIMEFRAMES=5m,15m,1h,4h
ENTRY_TIMEFRAMES=5m,15m
# Bars within which a fast/slow EMA cross still counts as a fresh trigger.
EMA_CROSS_LOOKBACK=3
# Higher-timeframe trend context the multi-timeframe module scores against.
# Swing adds the daily: CONTEXT_TIMEFRAMES=1h,4h,1d (and 1d in TIMEFRAMES).
CONTEXT_TIMEFRAMES=1h,4h

START_BALANCE=10000
MAX_RISK_PER_TRADE=1
MAX_DAILY_LOSS=3
MAX_OPEN_TRADES=1
MIN_CONFIDENCE_SCORE=70
MAX_SCORE_WITHOUT_LIQUIDITY_SWEEP=74
MAX_TRADES_PER_DAY=3
WORKER_INTERVAL_SECONDS=60
# Fast exit-monitoring between full signal cycles (ticker-only). Scalp uses 15.
MONITOR_INTERVAL_SECONDS=60
MARKOV_REGIME_ENABLED=true
MARKOV_REGIME_PENALTY=25
MARKOV_REGIME_VOLATILE_PENALTY=35
# Markov regime read per strategy: which two TFs feed the model + classification
# cutoffs. Scalp: 15m,1h with looser cutoffs; swing: 4h,1d with tighter ones.
MARKOV_CONTEXT_TIMEFRAMES=1h,4h
MARKOV_VOLATILE_THRESHOLD=0.0075
MARKOV_SIDEWAYS_THRESHOLD=0.00045
# ADX strong+aligned now ADDS points (not just a chop penalty).
ADX_TREND_BONUS=15
# Keltner volatility modules: extension gate (penalise overextended entries) and
# squeeze detector (reward breakouts out of compression).
KELTNER_PERIOD=20
KELTNER_ATR_MULT=1.5
EXTENSION_ATR_MULT=2.5
EXTENSION_PENALTY=15
SQUEEZE_ENABLED=true
SQUEEZE_BB_K=2
SQUEEZE_BONUS=15
# VWAP confluence: scalp-only (session VWAP resets each UTC day). Swing leaves off.
VWAP_ENABLED=false
VWAP_BONUS=15
# Structure-aware stops: anchor SL beyond the most recent swing low/high + ATR
# buffer, instead of a flat ATR distance. Take-profits scale with the risk used.
SWING_STRUCTURE_ENABLED=true
SWING_POINT_LOOKBACK=5
SWING_STOP_BUFFER_ATR=0.25
SWING_STOP_MAX_ATR=4
# Flash-wick breaker: block entries on abnormal liquidation wicks.
FLASH_WICK_ATR_MULT=3
FLASH_WICK_BODY_RATIO=0.35
FLASH_WICK_PENALTY=40
# Golden-setup eviction: a setup scoring >= GOLDEN_SCORE may evict the weakest
# open trade when the open-trade caps are full (if it outscores that trade).
GOLDEN_SCORE=90
# Daily report: per-strategy previous-day summary to Telegram once per local day.
DAILY_REPORT_ENABLED=true
# Per-signal Telegram alerts (off = only the daily report, on = every signal).
TELEGRAM_SIGNAL_ALERTS=false

BOT_ENABLED=true
KILL_SWITCH=false

MEXC_API_KEY=
MEXC_API_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

POSTGRES_DB=tradingplatformcodex
POSTGRES_USER=tradingplatformcodex
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://tradingplatformcodex:change_me@db:5432/tradingplatformcodex
REDIS_URL=redis://redis:6379
